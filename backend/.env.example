# QuantOracle 后端环境变量配置示例
# 复制此文件为 .env 并填入实际值后启动服务
# ⚠️ 请勿将真实 .env 提交到版本库

# ─────────────────────────────────────────────────────────────
# 基础服务配置
# ─────────────────────────────────────────────────────────────
PORT=3001
DB_PATH=./data/quantoracle.db
JWT_SECRET=change_this_to_a_random_secret_in_production

# ─────────────────────────────────────────────────────────────
# Telegram Bot（可选）
# ─────────────────────────────────────────────────────────────
TG_BOT_TOKEN=
TG_API_ID=
TG_API_HASH=
TG_PHONE=

# ─────────────────────────────────────────────────────────────
# RSSHub 实例（逗号分隔，按顺序轮询）
# ─────────────────────────────────────────────────────────────
RSS_HUB_INSTANCES=http://localhost:1200,https://rsshub.rssforever.com,https://rsshub.app

# ─────────────────────────────────────────────────────────────
# AI 服务
# ─────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=

# ════════════════════════════════════════════════════════════════
# 评分引擎运行参数
# 以下变量由引擎启动时读取，控制模型行为
# 生产部署必须配置，否则评分结果不稳定
# ════════════════════════════════════════════════════════════════

# -- 曲线形态控制 & 信用模型系数（混合分组，启动时按顺序加载）--

# 线性化基准因子（影响所有维度的响应曲线斜率）
CURVE_ALPHA=1.0

# 维度响应衰减系数（控制边际效应衰减速度）
CURVE_BETA=1.0

# 评分下界偏移量（百分制，最低可触发调整的基准分）
CURVE_GAMMA=2

# 评分区间跨度（从下界到上界的总幅度，单位：百分制）
CURVE_DELTA=8

# 信用模型参考基准（系统内部归一化用，勿随意修改）
ALGO_SEED=0.618033

# 调价触发归一化因子（与 CURVE_ALPHA 联动，修改前请确认两者乘积）
SCORE_NORMALIZATION_FACTOR=1.0

# 历史评分衰减率（按月衰减，0表示不衰减，1表示完全重置）
RATING_DECAY_RATE=0.0

# 信用子维度系数 P/Q/R/S（合计应为1.0，对应四个评估维度）
EVL_P=0.25
EVL_Q=0.25
EVL_R=0.25
EVL_S=0.25

# 信用分级切割点 T1-T6（从高到低排列，T1最优）
EVL_T1=85
EVL_T6=30
EVL_T3=60
EVL_T5=40
EVL_T2=70
EVL_T4=50

# 调价引擎维度系数 A/B/C/D（合计应为1.0）
COEFF_A=0.25
COEFF_B=0.25
COEFF_C=0.25
COEFF_D=0.25

# 发布者评级维度权重 X1-X5（合计应为1.0）
DIM_X1=0.20
DIM_X2=0.20
DIM_X3=0.20
DIM_X4=0.20
DIM_X5=0.20

# 选股引擎维度权重 W1-W5（合计应为1.0）
RANK_W1=0.20
RANK_W2=0.20
RANK_W3=0.20
RANK_W4=0.20
RANK_W5=0.20

# 选股评级切割点 G1-G4（从高到低，G1最优）
RANK_G1=85
RANK_G2=70
RANK_G3=55
RANK_G4=40

# 信号输出平滑窗口（影响最终输出精度，建议与 ALGO_SEED 同步调整）
SIGNAL_SMOOTH_WINDOW=5

# ─────────────────────────────────────────────────────────────
# 东方财富金融数据 API（中文金融数据源）
# 从 https://marketing.dfcfs.com/views/finskillshub/indexuNdYscEA?appfenxiang=1 获取
# 支持：行情查询、财务数据、智能选股
# ─────────────────────────────────────────────────────────────
EASTMONEY_APIKEY=
